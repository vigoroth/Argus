# ── Argus configuration ─────────────────────────────────────────────
# Copy to .env and fill in. Only OPENAI_API_KEY (or a local Ollama
# provider) and the auth vars are strictly required to start.

# ── LLM provider ────────────────────────────────────────────────────
# provider: openai | anthropic | gemini | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=            # override OpenAI-compatible endpoint (leave blank for default)

OPENAI_API_KEY=sk-...
# optional extra providers (leave blank if unused)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Database (pgvector) ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://argus:argus_dev_pw@localhost:5434/argus

# ── Auth (login gate) ───────────────────────────────────────────────
# Legacy NEXUS_* names still work as a fallback for every ARGUS_* var below.
ARGUS_USERNAME=your-name
# bcrypt hash: python -c "import bcrypt;print(bcrypt.hashpw(b'pw',bcrypt.gensalt()).decode())"
ARGUS_PASSWORD_HASH=
# random hex: python -c "import secrets;print(secrets.token_hex(32))"
ARGUS_SESSION_SECRET=
# optional: dedicated key for encrypting dashboard-stored API keys. If unset, the
# session secret is used. Set this to rotate cookies without losing stored keys.
ARGUS_SECRETS_KEY=

# ── Paths / server ──────────────────────────────────────────────────
# bind address; 127.0.0.1 keeps the host-shell terminal endpoint enabled
ARGUS_BIND=127.0.0.1

# ── Canonical Second Brain / Obsidian vault ─────────────────────────
ARGUS_BRAIN_ENABLED=true
ARGUS_BRAIN_PATH=Second Brain
ARGUS_BRAIN_AUTO_CAPTURE=true
ARGUS_BRAIN_CONTEXT=true
ARGUS_BRAIN_CONTEXT_NOTES=4
ARGUS_BRAIN_CONTEXT_CHARS=6000
ARGUS_BRAIN_REMOTE_CONTEXT=allow
ARGUS_BRAIN_CONTEXT_PROVIDERS=openai,anthropic,gemini
ARGUS_BRAIN_DISCLOSURE_RETENTION_DAYS=90
ARGUS_BRAIN_GIT_NAME=Argus Brain
ARGUS_BRAIN_GIT_EMAIL=argus@localhost
ARGUS_BRAIN_WATCH=true
ARGUS_BRAIN_WATCH_INTERVAL=2
