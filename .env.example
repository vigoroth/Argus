# ── Argus configuration ─────────────────────────────────────────────
# Copy to .env and fill in. Only OPENAI_API_KEY (or a local Ollama
# provider) and the auth vars are strictly required to start.

# ── LLM provider ────────────────────────────────────────────────────
# provider: openai | anthropic | gemini | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=            # override OpenAI-compatible endpoint (leave blank for default)

OPENAI_API_KEY=sk-...
# optional extra providers (leave blank if unused)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Database (pgvector) ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://argus:argus_dev_pw@localhost:5434/argus

# ── Auth (login gate) ───────────────────────────────────────────────
# Legacy NEXUS_* names still work as a fallback for every ARGUS_* var below.
ARGUS_USERNAME=your-name
# bcrypt hash: python -c "import bcrypt;print(bcrypt.hashpw(b'pw',bcrypt.gensalt()).decode())"
ARGUS_PASSWORD_HASH=
# random hex: python -c "import secrets;print(secrets.token_hex(32))"
ARGUS_SESSION_SECRET=

# ── Paths / server ──────────────────────────────────────────────────
# Obsidian vault for the knowledge graph (graphify writes here)
ARGUS_VAULT_PATH=
# bind address; 127.0.0.1 keeps the host-shell terminal endpoint enabled
ARGUS_BIND=127.0.0.1
